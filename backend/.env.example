# Copy this file to .env and fill in your values.
# NOTE: Do NOT commit the .env file — it contains credentials.

# PostgreSQL connection URL
# Default port is 5432. If your PostgreSQL runs on a different port (e.g. 5433), change it here.
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/your_database

SECRET_KEY=change_me_to_a_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS: comma-separated list of allowed frontend origins.
# When set, credentials (cookies/auth headers) are allowed for these origins.
# When omitted, CORS falls back to allow_origins=["*"] with credentials disabled.
# FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173
