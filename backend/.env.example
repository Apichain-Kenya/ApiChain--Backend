# Copy this file to .env and fill in your values.
# NOTE: Do NOT commit the .env file — it contains credentials.

# PostgreSQL connection URL
# Default port is 5432. If your PostgreSQL runs on a different port (e.g. 5433), change it here.
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/your_database

SECRET_KEY=change_me_to_a_random_string
# Wallet encryption key used by app/services/encryption.py.
# Generate a Fernet key with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WALLET_ENCRYPTION_KEY=replace_with_a_generated_fernet_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS: comma-separated list of allowed frontend origins.
# When set, credentials (cookies/auth headers) are allowed for these origins.
# When omitted, CORS falls back to allow_origins=["*"] with credentials disabled.
# FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173

# Blockchain configuration
# For Hardhat local: http://127.0.0.1:8545, CHAIN_ID=31337
# For Sepolia testnet: use your Alchemy/Infura RPC URL, CHAIN_ID=11155111
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
ADMIN_PRIVATE_KEY=0x_your_admin_private_key
ORACLE_PRIVATE_KEY=0x_your_oracle_private_key
ROLE_MANAGER_ADDRESS=0x_deployed_role_manager_address
REGISTRY_ADDRESS=0x_deployed_registry_address
CHAIN_ID=31337
