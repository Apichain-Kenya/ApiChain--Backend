#!/bin/bash
# post-merge hook -- updates .claude/CLAUDE.md auto-generated sections
# Runs automatically after: git pull, git merge
#
# Install this hook by running: bash .claude/setup-hooks.sh

REPO_ROOT=$(git rev-parse --show-toplevel)
SCRIPT="$REPO_ROOT/.claude/update_claude_md.py"

if [ -f "$SCRIPT" ]; then
    echo "[post-merge] Updating .claude/CLAUDE.md auto-generated sections..."

    # Try the project's venv first, fall back to system python
    if [ -f "$REPO_ROOT/backend/.venv/Scripts/python.exe" ]; then
        "$REPO_ROOT/backend/.venv/Scripts/python.exe" "$SCRIPT"
    elif [ -f "$REPO_ROOT/backend/.venv/bin/python" ]; then
        "$REPO_ROOT/backend/.venv/bin/python" "$SCRIPT"
    else
        python "$SCRIPT"
    fi

    echo "[post-merge] CLAUDE.md updated."
fi
